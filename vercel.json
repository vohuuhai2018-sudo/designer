{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm --prefix LandscapeApp install && npm --prefix LandscapeApp/server install",
  "buildCommand": "npm --prefix LandscapeApp run build",
  "outputDirectory": "LandscapeApp/dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
