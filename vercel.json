{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm --prefix LandscapeApp install",
  "buildCommand": "npm --prefix LandscapeApp run build",
  "outputDirectory": "LandscapeApp/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
